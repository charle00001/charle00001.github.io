</span></span></span><span style="display:flex;"><span><span style="color:#75715e"></span>            <span style="color:#a6e22e">setCookie</span>(<span style="color:#e6db74">&#34;disclaimer&#34;</span>, <span style="color:#e6db74">&#34;同意&#34;</span>);
</span></span><span style="display:flex;"><span>            <span style="color:#75715e">// 显示已同意的提示消息
</span></span></span><span style="display:flex;"><span><span style="color:#75715e"></span>            window.<span style="color:#a6e22e">alert</span>(<span style="color:#e6db74">&#34;您已同意使用cookie.&#34;</span>);
</span></span><span style="display:flex;"><span>        } <span style="color:#66d9ef">else</span> {
