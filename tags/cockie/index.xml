</span></span></span><span style="display:flex;"><span><span style="color:#75715e"></span>            window.<span style="color:#a6e22e">location</span>.<span style="color:#a6e22e">href</span> <span style="color:#f92672">=</span> <span style="color:#e6db74">&#34;about:blank&#34;</span>;
