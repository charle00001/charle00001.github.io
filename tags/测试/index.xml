</span></span><span style="display:flex;"><span>        <span style="color:#75715e">// 检查是否存在名为 &#34;disclaimer&#34; 的 Cookie
</span></span></span><span style="display:flex;"><span><span style="color:#75715e"></span>        <span style="color:#66d9ef">var</span> <span style="color:#a6e22e">disclaimerCookie</span> <span style="color:#f92672">=</span> <span style="color:#a6e22e">getCookie</span>(<span style="color:#e6db74">&#34;disclaimer&#34;</span>);
</span></span><span style="display:flex;"><span>        <span style="color:#66d9ef">if</span> (<span style="color:#a6e22e">disclaimerCookie</span> <span style="color:#f92672">===</span> <span style="color:#e6db74">&#34;同意&#34;</span>) {
</span></span><span style="display:flex;"><span>            <span style="color:#75715e">// 如果存在 &#34;disclaimer&#34; Cookie，并且值为 &#34;同意&#34;，则不显示弹窗
</span></span></span><span style="display:flex;"><span><span style="color:#75715e"></span>            <span style="color:#66d9ef">return</span>;
</span></span><span style="display:flex;"><span>        }
</span></span><span style="display:flex;"><span>
</span></span><span style="display:flex;"><span>        <span style="color:#75715e">// 显示弹窗
</span></span></span><span style="display:flex;"><span><span style="color:#75715e"></span>        <span style="color:#66d9ef">var</span> <span style="color:#a6e22e">disclaimer</span> <span style="color:#f92672">=</span> <span style="color:#e6db74">&#34;这是一个测试弹窗，当你同意cookie后不会再显示对话框.&#34;</span>;
</span></span><span style="display:flex;"><span>        window.<span style="color:#a6e22e">alert</span>(<span style="color:#a6e22e">disclaimer</span>);
</span></span><span style="display:flex;"><span>
